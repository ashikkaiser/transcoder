# ── Server ────────────────────────────────────────────
HOST=0.0.0.0
PORT=3000

# ── Cloudflare R2 ────────────────────────────────────
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=your_bucket_name
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ── Callback ─────────────────────────────────────────
# Base URL prepended when callback_url is relative
CALLBACK_BASE_URL=https://your-api.example.com
# Auth type: none | bearer_token | api_key
CALLBACK_AUTH_TYPE=none
# Secret sent with callback requests (leave empty for no auth)
CALLBACK_SECRET=

# ── Workers ──────────────────────────────────────────
WORKER_CONCURRENCY=2
MAX_JOB_ATTEMPTS=5

# ── FFmpeg ───────────────────────────────────────────
# Comma-separated rendition presets to enable
ENABLED_RENDITIONS=360p,720p,1080p
# Base prefix for HLS output paths in S3/R2 (e.g. "hls", "transcoded", "output/videos")
OUTPUT_PATH_PREFIX=hls
# Hardware acceleration: auto | cpu | videotoolbox | nvenc | qsv | vaapi
# "auto" detects and uses the best available GPU encoder, falling back to CPU
HW_ACCEL=auto

# ── Source Cleanup ────────────────────────────────────
# Delete the original MP4 from R2/S3 after successful transcode + callback
DELETE_SOURCE_AFTER_TRANSCODE=false

# ── Storage ──────────────────────────────────────────
TEMP_DIR=/tmp/transcoder
DATABASE_URL=sqlite:transcoder.db

# ── Admin UI ─────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ── API Authentication ───────────────────────────────
# When set, API routes require this key via X-API-Key header
# or Authorization: Bearer <key>. Leave empty for open access.
API_KEY=

# ── Poll / Pull Mode ─────────────────────────────────
# Enable periodic polling of an external API for pending videos
POLL_ENABLED=false
# Endpoint URL that returns pending videos (GET)
# Expected JSON: { "data": [{ "id": 123, "s3_key": "...", "video_url": "...", "callback_url": "" }] }
POLL_ENDPOINT=
# How often to poll in seconds (minimum 5)
POLL_INTERVAL_SECS=30
# Auth type for the poll endpoint: none | bearer_token | api_key
POLL_AUTH_TYPE=none
# Secret/token for authenticating poll requests
POLL_AUTH_SECRET=

# ── Logging (RUST_LOG style) ─────────────────────────
RUST_LOG=video_transcoder=info,tower_http=info
